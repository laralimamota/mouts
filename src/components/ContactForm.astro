---
import { site, whatsappHref } from "../data/site";

// PLACEHOLDER: trocar pelo endpoint real (Formspree/Getform/backend próprio).
// Enquanto não houver endpoint, o CTA do WhatsApp ao lado já funciona.
const FORM_ENDPOINT = "https://formspree.io/f/SEU_FORM_ID";
---

<section id="contato" class="relative scroll-mt-24 py-[var(--section-y)]">
  <div
    aria-hidden="true"
    class="pointer-events-none absolute bottom-0 left-1/2 h-[28rem] w-[40rem] -translate-x-1/2 rounded-full bg-accent/10 blur-[130px]"
  >
  </div>

  <div class="relative mx-auto max-w-7xl px-5 sm:px-8">
    <div class="grid gap-12 lg:grid-cols-[1fr_1fr] lg:gap-20">
      <div class="reveal">
        <p
          class="mb-8 flex items-center gap-3 text-xs font-medium uppercase tracking-[0.25em] text-ash"
        >
          <span class="inline-block h-px w-8 bg-accent" aria-hidden="true"></span>
          Contato
        </p>
        <h2
          class="font-display text-[clamp(2.25rem,6vw,5rem)] font-black leading-[0.95] tracking-tight text-bone"
        >
          Bora<br />conversar<span class="reg" aria-hidden="true">©</span>
        </h2>
        <p class="mt-8 max-w-md text-lg leading-relaxed text-ash">
          Conte seu projeto e receba um orçamento. Resposta rápida, direto pelo
          WhatsApp.
        </p>

        <div class="mt-10 flex flex-col gap-4">
          <a
            href={whatsappHref()}
            class="inline-flex w-fit items-center gap-3 rounded-full bg-accent px-7 py-3.5 text-base font-semibold text-ink transition-transform hover:-translate-y-0.5"
          >
            Whatsapp
          </a>
        </div>
      </div>

      <!-- Formulário: validação nativa (zero JS). -->
      <form
        class="reveal flex flex-col gap-5 rounded-2xl border border-line bg-ink-soft p-7 sm:p-9"
        action={FORM_ENDPOINT}
        method="POST"
      >
        <div class="flex flex-col gap-2">
          <label for="nome" class="text-sm font-medium text-ash">Nome</label>
          <input
            id="nome"
            name="nome"
            type="text"
            required
            autocomplete="name"
            class="rounded-lg border border-line bg-ink px-4 py-3 text-bone placeholder:text-ash-dim focus:border-accent"
            placeholder="Seu nome"
          />
        </div>

        <div class="flex flex-col gap-2">
          <label for="empresa" class="text-sm font-medium text-ash">
            Empresa
          </label>
          <input
            id="empresa"
            name="empresa"
            type="text"
            autocomplete="organization"
            class="rounded-lg border border-line bg-ink px-4 py-3 text-bone placeholder:text-ash-dim focus:border-accent"
            placeholder="Nome da empresa (opcional)"
          />
        </div>

        <div class="flex flex-col gap-2">
          <label for="email" class="text-sm font-medium text-ash">E-mail</label>
          <input
            id="email"
            name="email"
            type="email"
            required
            autocomplete="email"
            class="rounded-lg border border-line bg-ink px-4 py-3 text-bone placeholder:text-ash-dim focus:border-accent"
            placeholder="voce@empresa.com"
          />
        </div>

        <div class="flex flex-col gap-2">
          <label for="mensagem" class="text-sm font-medium text-ash">
            Sobre o projeto
          </label>
          <textarea
            id="mensagem"
            name="mensagem"
            rows="4"
            required
            class="resize-y rounded-lg border border-line bg-ink px-4 py-3 text-bone placeholder:text-ash-dim focus:border-accent"
            placeholder="Tipo de vídeo, prazo, objetivo..."></textarea>
        </div>

        <button
          type="submit"
          class="mt-2 rounded-full bg-bone px-7 py-3.5 text-base font-semibold text-ink transition-transform hover:-translate-y-0.5"
        >
          Enviar mensagem
        </button>

      </form>
    </div>
  </div>
</section>
