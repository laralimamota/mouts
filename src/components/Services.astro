---
import { services, whatsappHref } from "../data/site";
---

<section id="servicos" class="relative scroll-mt-28 py-[var(--section-y)]">
  <div class="mx-auto max-w-7xl px-5 sm:px-8">
    <header class="reveal mx-auto mb-14 max-w-3xl text-center">
      <p
        class="mb-6 flex items-center justify-center gap-3 text-xs font-medium uppercase tracking-[0.25em] text-ash"
      >
        <span class="inline-block h-px w-8 bg-accent" aria-hidden="true"></span>
        Serviços
        <span class="inline-block h-px w-8 bg-accent" aria-hidden="true"></span>
      </p>
      <h2
        class="font-display text-[clamp(2rem,5.5vw,4rem)] font-extrabold leading-[1.02] tracking-tight text-bone"
      >
        Tudo o que sua marca precisa em audiovisual
      </h2>
    </header>

    <div
      class="grid grid-cols-2 gap-4 sm:gap-5 lg:grid-cols-3 xl:grid-cols-5"
    >
      {
        services.map((service) => (
          <article class="reveal group relative aspect-[3/4] overflow-hidden rounded-3xl border border-line bg-ink-soft transition-transform duration-500 hover:z-20 hover:scale-[1.1] hover:border-accent/40 hover:shadow-2xl hover:shadow-black/60">
            <video
              class="absolute inset-0 h-full w-full object-cover opacity-65 transition-opacity duration-500 group-hover:opacity-100"
              data-autoplay
              autoplay
              muted
              loop
              playsinline
              preload="none"
              poster="/work-poster.svg"
              aria-hidden="true"
              tabindex="-1"
            >
              <source src={service.media} type="video/mp4" />
            </video>

            <div
              class="absolute inset-0 bg-gradient-to-t from-ink via-ink/55 to-ink/10 transition-opacity duration-500 group-hover:opacity-70"
              aria-hidden="true"
            />

            <div class="absolute inset-x-0 bottom-0 p-4 text-center sm:p-6">
              <h3 class="font-display text-base font-bold leading-tight tracking-tight text-bone sm:text-lg lg:text-xl">
                {service.title}
              </h3>
              <p class="mx-auto mt-2 max-w-[28ch] text-xs leading-relaxed text-ash transition-colors group-hover:text-bone/90 sm:text-sm">
                {service.description}
              </p>
            </div>
          </article>
        ))
      }
    </div>

    <div class="reveal mt-12 flex justify-center">
      <a
        href={whatsappHref(
          "Olá, vim do site e gostaria de contratar os serviços da CINE!",
        )}
        class="rounded-full border border-line px-7 py-3.5 text-base font-medium text-bone transition-colors hover:border-bone/40"
      >
        Quero contratar os serviços
      </a>
    </div>
  </div>
</section>
