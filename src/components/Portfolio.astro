---
import Section from "./Section.astro";
import WorkCard from "./WorkCard.astro";
import { works, whatsappHref } from "../data/site";
---

<Section id="trabalhos" label="Trabalhos">
  <div
    class="reveal mb-10 flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between"
  >
    <h2
      class="max-w-2xl font-display text-[clamp(2rem,5vw,3.75rem)] font-extrabold leading-[1.02] tracking-tight text-bone"
    >
      Cases que confiaram em nosso trabalho.
    </h2>
    <p class="max-w-sm text-base leading-relaxed text-ash">
      Empresas que enxergam o audiovisual como investimento estratégico.
    </p>
  </div>
</Section>

<!-- Carrossel lateral: setas sobrepostas + barra de progresso -->
<div class="reveal relative mx-auto max-w-7xl">
  <button
    type="button"
    data-carousel-prev
    aria-label="Anterior"
    class="absolute left-2 top-[34%] z-10 grid h-12 w-12 -translate-y-1/2 place-items-center rounded-full border border-line bg-ink/80 text-bone backdrop-blur transition-all hover:border-accent hover:text-accent disabled:pointer-events-none disabled:opacity-0 sm:left-3"
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"></path></svg>
  </button>
  <button
    type="button"
    data-carousel-next
    aria-label="Próximo"
    class="absolute right-2 top-[34%] z-10 grid h-12 w-12 -translate-y-1/2 place-items-center rounded-full border border-line bg-ink/80 text-bone backdrop-blur transition-all hover:border-accent hover:text-accent disabled:pointer-events-none disabled:opacity-0 sm:right-3"
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"></path></svg>
  </button>

  <div
    data-carousel-track
    class="no-scrollbar flex snap-x snap-mandatory gap-2 overflow-x-auto px-5 pb-1 sm:px-8"
    role="list"
    aria-label="Cases em vídeo, role horizontalmente"
    tabindex="0"
  >
    {works.map((work) => <WorkCard work={work} />)}
  </div>

  <!-- Barra de progresso -->
  <div class="mt-7 px-5 sm:px-8">
    <div class="relative h-[3px] w-full overflow-hidden rounded-full bg-line">
      <span
        data-carousel-progress
        class="absolute left-0 top-0 h-full rounded-full bg-accent transition-[width,left] duration-150"
        style="width: 25%"
      ></span>
    </div>
  </div>
</div>

<div class="mx-auto max-w-7xl px-5 sm:px-8">
  <div class="reveal mt-10 flex justify-center">
    <a
      href={whatsappHref(
        "Olá, vim do site e gostaria de me tornar um case da CINE!",
      )}
      class="rounded-full bg-accent px-7 py-3.5 text-base font-semibold text-ink transition-transform hover:-translate-y-0.5"
    >
      Quero me tornar um case
    </a>
  </div>
</div>

<script>
  const track = document.querySelector<HTMLElement>("[data-carousel-track]");
  const prev = document.querySelector<HTMLButtonElement>("[data-carousel-prev]");
  const next = document.querySelector<HTMLButtonElement>("[data-carousel-next]");
  const bar = document.querySelector<HTMLElement>("[data-carousel-progress]");

  if (track) {
    const step = () => {
      const card = track.querySelector<HTMLElement>(":scope > *");
      const gap = parseFloat(getComputedStyle(track).columnGap || "20") || 20;
      return card ? card.offsetWidth + gap : track.clientWidth * 0.8;
    };

    const update = () => {
      const max = track.scrollWidth - track.clientWidth;
      const ratio = max > 0 ? track.scrollLeft / max : 0;
      const visible = Math.min(1, track.clientWidth / track.scrollWidth);
      if (bar) {
        bar.style.width = `${visible * 100}%`;
        bar.style.left = `${ratio * (1 - visible) * 100}%`;
      }
      if (prev) prev.disabled = track.scrollLeft <= 1;
      if (next) next.disabled = track.scrollLeft >= max - 1;
    };

    prev?.addEventListener("click", () =>
      track.scrollBy({ left: -step(), behavior: "smooth" }),
    );
    next?.addEventListener("click", () =>
      track.scrollBy({ left: step(), behavior: "smooth" }),
    );
    track.addEventListener("scroll", update, { passive: true });
    window.addEventListener("resize", update);
    update();
  }
</script>
