---
import { whatsappHref, works } from "../data/site";

// Showreel: usamos um dos cases reais como vídeo em destaque.
const showreel = works[0];
---

<section id="topo" class="relative overflow-hidden pt-32 pb-16 sm:pt-40 sm:pb-24">
  <!-- brilho âmbar de fundo, sutil -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -top-40 left-1/2 h-[36rem] w-[36rem] -translate-x-1/2 rounded-full bg-accent/10 blur-[120px]"
  >
  </div>

  <div class="relative mx-auto max-w-7xl px-5 sm:px-8">
    <p
      class="mb-8 flex items-center gap-3 text-xs font-medium uppercase tracking-[0.25em] text-ash"
    >
      <span class="inline-block h-px w-8 bg-accent" aria-hidden="true"></span>
      Produtora de audiovisual · Rio Verde–GO
    </p>

    <h1
      class="font-display text-[clamp(2.75rem,11vw,9rem)] font-black leading-[0.92] tracking-[-0.03em] text-bone"
    >
      EXPERIÊNCIA<br />
      QUE GERA VALOR<span class="reg" aria-hidden="true">©</span>
    </h1>

    <div class="mt-10 grid gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-end">
      <p class="max-w-xl text-lg leading-relaxed text-ash sm:text-xl">
        Transformamos convenções, dias de campo e histórias institucionais em
        filmes com <span class="text-bone">estética cinematográfica</span> —
        que geram percepção de valor, conexão e resultado.
      </p>

      <div class="flex flex-wrap items-center gap-4 lg:justify-end">
        <a
          href={whatsappHref()}
          class="rounded-full bg-accent px-7 py-3.5 text-base font-semibold text-ink transition-transform hover:-translate-y-0.5"
        >
          Quero receber um orçamento
        </a>
        <a
          href="#trabalhos"
          class="rounded-full border border-line px-7 py-3.5 text-base font-medium text-bone transition-colors hover:border-bone/40"
        >
          Ver trabalhos
        </a>
      </div>
    </div>

    <!-- Showreel em destaque: lazy (preload=none), controles nativos, zero JS -->
    <figure class="reveal mt-14 sm:mt-20">
      <div
        class="relative overflow-hidden rounded-2xl border border-line bg-ink-soft"
      >
        <video
          class="aspect-video w-full object-cover"
          controls
          playsinline
          preload="none"
          poster="/showreel-poster.svg"
          aria-label={`Showreel — ${showreel.title}`}
        >
          <source src={showreel.src} type={showreel.type} />
          Seu navegador não suporta vídeo HTML5.
        </video>
      </div>
      <figcaption class="mt-3 text-sm text-ash-dim">
        Showreel · destaque: {showreel.title}
      </figcaption>
    </figure>
  </div>
</section>
