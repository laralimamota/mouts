---
import { site, nav, whatsappHref } from "../data/site";

const addressLabel = `${site.city} — ${site.state}`;
const mapsHref = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(
  `${site.city} ${site.state}`,
)}`;

// ícones inline (14px) — sem dependências externas
function icon(name: string): string {
  const s =
    'width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"';
  switch (name) {
    case "pin":
      return `<svg ${s}><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`;
    case "mail":
      return `<svg ${s}><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>`;
    case "whatsapp":
      return `<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12.04 2a9.9 9.9 0 0 0-8.49 14.96L2 22l5.18-1.36A9.9 9.9 0 1 0 12.04 2Zm0 1.8a8.1 8.1 0 0 1 6.86 12.42l-.2.32.86 3.14-3.2-.84-.31.18a8.1 8.1 0 1 1-4-15.22ZM8.5 7.3c-.17 0-.44.06-.67.31-.23.25-.88.86-.88 2.1s.9 2.43 1.03 2.6c.13.17 1.77 2.83 4.4 3.86 2.18.86 2.62.69 3.09.64.47-.04 1.52-.62 1.74-1.22.21-.6.21-1.1.15-1.21-.06-.1-.23-.17-.48-.3-.25-.12-1.52-.75-1.76-.83-.23-.09-.4-.13-.57.12-.17.25-.65.83-.8 1-.14.17-.29.19-.54.06-.25-.12-1.06-.39-2.02-1.25-.75-.66-1.25-1.48-1.4-1.73-.14-.25-.01-.38.11-.5.11-.11.25-.29.38-.43.12-.15.16-.25.25-.42.08-.17.04-.31-.02-.44-.06-.12-.55-1.37-.77-1.87-.2-.48-.4-.42-.55-.43h-.47Z"/></svg>`;
    case "instagram":
      return `<svg ${s}><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/></svg>`;
    default:
      return "";
  }
}

// Itens de contato reaproveitados na barra superior e no menu mobile.
const contacts = [
  { label: addressLabel, href: mapsHref, icon: "pin", external: true },
  { label: site.email, href: `mailto:${site.email}`, icon: "mail", external: false },
  {
    label: site.whatsapp.display,
    href: whatsappHref(),
    icon: "whatsapp",
    external: true,
  },
  { label: "Instagram", href: site.social.instagram, icon: "instagram", external: true },
];
---

<header class="fixed inset-x-0 top-0 z-40 bg-ink/70 backdrop-blur-md">
  <!-- Barra de contato (canto superior direito) — desktop -->
  <div class="hidden border-b border-line/50 lg:block">
    <div class="mx-auto flex max-w-7xl items-center justify-end gap-6 px-8 py-2">
      {
        contacts.map((c) => (
          <a
            href={c.href}
            target={c.external ? "_blank" : undefined}
            rel={c.external ? "noopener" : undefined}
            aria-label={c.label}
            title={c.label}
            class="text-ash transition-colors hover:text-accent"
          >
            <span set:html={icon(c.icon)} aria-hidden="true" />
          </a>
        ))
      }
    </div>
  </div>

  <!-- Linha principal -->
  <nav aria-label="Navegação principal" class="border-b border-line/60">
    <div
      class="mx-auto flex max-w-7xl items-center justify-between px-5 py-4 sm:px-8"
    >
      <a
        href="#topo"
        class="flex items-center"
        aria-label={`${site.name} — início`}
      >
        <img
          src="/cine-logo.png"
          alt={`${site.name} — produtora audiovisual`}
          width="56"
          height="56"
          class="h-11 w-auto sm:h-12"
        />
      </a>

      <ul class="hidden items-center gap-8 md:flex">
        {
          nav.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-sm font-medium text-ash transition-colors hover:text-bone"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>

      <div class="flex items-center gap-3">
        <a
          href={whatsappHref()}
          class="hidden rounded-full bg-accent px-5 py-2 text-sm font-semibold text-ink transition-transform hover:-translate-y-0.5 sm:inline-block"
        >
          Orçamento
        </a>

        <!-- Menu mobile: disclosure CSS-only (zero JS) -->
        <details class="relative md:hidden">
          <summary
            class="flex cursor-pointer list-none items-center gap-2 text-sm font-medium text-bone marker:hidden"
            aria-label="Abrir menu"
          >
            <span>Menu</span>
          </summary>
          <ul
            class="absolute right-0 mt-3 w-60 rounded-xl border border-line bg-ink-soft p-2 shadow-2xl"
          >
            {
              nav.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class="block rounded-lg px-4 py-2.5 text-sm text-ash transition-colors hover:bg-line hover:text-bone"
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
            <li class="my-2 border-t border-line"></li>
            {
              contacts.map((c) => (
                <li>
                  <a
                    href={c.href}
                    target={c.external ? "_blank" : undefined}
                    rel={c.external ? "noopener" : undefined}
                    class="flex items-center gap-2 rounded-lg px-4 py-2 text-xs text-ash transition-colors hover:bg-line hover:text-bone"
                  >
                    <span class="text-accent" set:html={icon(c.icon)} aria-hidden="true" />
                    {c.label}
                  </a>
                </li>
              ))
            }
            <li>
              <a
                href={whatsappHref()}
                class="mt-1 block rounded-lg bg-accent px-4 py-2.5 text-center text-sm font-semibold text-ink"
              >
                Orçamento
              </a>
            </li>
          </ul>
        </details>
      </div>
    </div>
  </nav>
</header>
