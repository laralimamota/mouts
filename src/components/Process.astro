---
import Section from "./Section.astro";
import { process } from "../data/site";
---

<Section id="processo" label="Processo">
  <div class="grid gap-12 lg:grid-cols-[0.8fr_1.2fr] lg:gap-16">
    <h2
      class="reveal font-display text-[clamp(2rem,5vw,3.75rem)] font-extrabold leading-[1.02] tracking-tight text-bone lg:sticky lg:top-28 lg:self-start"
    >
      Linguagem de cinema, agilidade de entrega.
    </h2>

    <ol class="flex flex-col">
      {
        process.map((stage) => (
          <li class="reveal grid grid-cols-[auto_1fr] gap-5 border-t border-line py-8 last:border-b sm:gap-8">
            <span class="font-display text-2xl font-black tabular-nums text-accent sm:text-3xl">
              {stage.step}
            </span>
            <div>
              <h3 class="font-display text-xl font-bold tracking-tight text-bone sm:text-2xl">
                {stage.title}
              </h3>
              <p class="mt-2 max-w-prose text-base leading-relaxed text-ash">
                {stage.description}
              </p>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</Section>
