---
import { videoFeature } from "../data/site";
const f = videoFeature;
---

<section class="relative scroll-mt-28 py-[var(--section-y)]">
  <div class="mx-auto max-w-7xl px-5 sm:px-8">
    <div class="grid items-center gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:gap-16">
      <div class="reveal">
        <p
          class="mb-8 flex items-center gap-3 text-xs font-medium uppercase tracking-[0.25em] text-ash"
        >
          <span class="inline-block h-px w-8 bg-accent" aria-hidden="true"></span>
          {f.label}
        </p>
        <h2
          class="font-display text-[clamp(2rem,5vw,3.75rem)] font-extrabold leading-[1.02] tracking-tight text-bone"
        >
          {f.heading}
        </h2>
        <p class="mt-6 max-w-md text-lg leading-relaxed text-ash">
          {f.body}
        </p>
      </div>

      <!-- Vídeo mudo em loop (autoplay gerenciado por visibilidade) -->
      <figure
        class="reveal relative overflow-hidden rounded-3xl border border-line bg-ink-soft"
      >
        <video
          class="aspect-video w-full object-cover"
          data-autoplay
          autoplay
          muted
          loop
          playsinline
          preload="none"
          poster="/work-poster.svg"
          aria-label={`Bastidores — ${f.heading}`}
        >
          <source src={f.media} type="video/mp4" />
        </video>
      </figure>
    </div>
  </div>
</section>
